{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "EPD document map",
  "description": "Table of contents / index tree from an EPD PDF",
  "type": "object",
  "properties": {
    "toc_title": {
      "type": ["string", "null"],
      "description": "Heading above the index, e.g. 'TABLE OF CONTENTS'"
    },
    "source_pages": {
      "type": "array",
      "items": { "type": "integer" },
      "description": "1-based PDF pages used to build the index"
    },
    "entries": {
      "type": "array",
      "description": "Top-level index nodes (nested via children)",
      "items": { "$ref": "#/$defs/tocNode" }
    },
    "flat_entries": {
      "type": "array",
      "description": "All entries in document order (flat list with level)",
      "items": {
        "type": "object",
        "properties": {
          "number": { "type": "string" },
          "title": { "type": "string" },
          "page": { "type": ["integer", "null"] },
          "level": { "type": "integer" }
        },
        "required": ["number", "title", "page", "level"]
      }
    }
  },
  "required": ["source_pages", "entries", "flat_entries"],
  "$defs": {
    "tocNode": {
      "type": "object",
      "properties": {
        "number": { "type": "string" },
        "title": { "type": "string" },
        "page": { "type": ["integer", "null"] },
        "level": { "type": "integer" },
        "children": {
          "type": "array",
          "items": { "$ref": "#/$defs/tocNode" }
        }
      },
      "required": ["number", "title", "page", "level"]
    }
  }
}

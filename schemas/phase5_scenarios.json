{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "EPD Scenarios",
  "description": "Phase 5 output: lifecycle scenario assumptions (typically section 10)",
  "type": "object",
  "properties": {
    "section_title": {
      "type": ["string", "null"],
      "description": "Heading of the scenarios section"
    },
    "scenarios": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "module": {
            "type": ["string", "null"],
            "description": "Lifecycle module code, e.g. A1, A4, A5, B, C, D"
          },
          "number": {
            "type": ["string", "null"],
            "description": "Section number when shown, e.g. 10.4"
          },
          "title": { "type": ["string", "null"] },
          "description": {
            "type": ["string", "null"],
            "description": "Verbatim scenario text for this module"
          }
        },
        "required": ["module", "number", "title", "description"]
      }
    }
  },
  "required": ["section_title", "scenarios"]
}

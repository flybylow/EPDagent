{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "EPD Draft Template",
  "description": "Declarative layout for formatted digital drafts from phase extraction JSON",
  "type": "object",
  "required": ["id", "version", "title", "sections"],
  "properties": {
    "id": { "type": "string" },
    "version": { "type": "string" },
    "title": { "type": "string" },
    "sections": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "fields"],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "fields": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "label", "path"],
              "properties": {
                "id": { "type": "string" },
                "label": { "type": "string" },
                "path": {
                  "type": "string",
                  "description": "Dot path into merged phase data, e.g. phase2.producer.name"
                },
                "format": { "enum": ["text", "date", "enum"] },
                "enumLabels": {
                  "type": "object",
                  "additionalProperties": { "type": "string" }
                }
              }
            }
          }
        }
      }
    }
  }
}

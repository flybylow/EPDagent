# Anthropic API key (required for phase 2 PDF extraction)
ANTHROPIC_API_KEY=

# API budget guards (see docs/api-budget-policy.md)
# EPDAGENT_PHASE2_PAGES=1-4
# EPDAGENT_PHASE3_PAGES=2-4
# EPDAGENT_MAX_API_PDF_BYTES=1048576
# EPDAGENT_MAX_PDF_BYTES=5242880
# EPDAGENT_ALLOW_BULK_API=1
# EPDAGENT_PHASE3_COMPOSITION_PAGES=3

# JSON-LD @id base (default: http://localhost:3000/id)
EPDAGENT_IRI_BASE=http://localhost:3000/id

# Folder with BEBD EPD PDFs — default is data/EPD (no need to set this)
# EPDAGENT_PDF_DIR=data/EPD
EPDAGENT_PDF_DIR=

    {
      "@id": "http://localhost:3000/id/operator/B-EPD",
      "@type": "ProgramOperator",
      "schema:name": "Federal Public Service of Health, Food Chain Safety and Environment",
      "operatorCode": "B-EPD"
    },
    {
      "@id": "http://localhost:3000/id/org/1128b282827d",
      "@type": "schema:Organization",
      "schema:name": "Orbix & Betonagglomeraten Gubbels N.V.",
      "schema:address": null,
      "schema:addressCountry": "BE"
    },
    {
      "@id": "http://localhost:3000/id/person/f65746f88cd1",
      "@type": "schema:Person",
      "schema:name": "Vinçotte nv",
      "verificationType": "independent_third_party"
    },
    {
      "@id": "http://localhost:3000/id/epd/http%3A%2F%2Flocalhost%3A3000%2Fid%2Fepd%2FB-EPD%2520025.0262.004-01.00.00%2520Beton%2520Agglo%2520Carbstones%2520Kimblok%2520EN%2520-%2520signed/product",
      "@type": "ProductSection",
      "description": "Carbstones are carbonated full bricks with dimensions .The applied carbonation technique, developed by Orbix, transforms metal slag from the steel industry into circular building products.\n\nCarbstones have the characteristic of absorbing CO2 through carbonation. This happens because the Carbstones have metal slag as ingredients, which is a calcium-rich material. The calcium reacts with water and CO2 to form calcium carbonate, a strong binder. Because of this, the Carbstone has a binding agent of CO2 instead of cement. The building material has the same characteristics as a concrete block. The difference is in capturing the CO2.\n\nThe Carbstones are attached to each other using a specific glue for Carbstones. This EPD reports the results for 1 m2.",
      "intendedUse": "The Carbstones can be used for constructive and non-constructive interior walls.",
      "installation": "Materials for fixation and installation are included. This EPD includes the impacts of all processes, fixating materials, jointing material or treatments necessary for installing/mounting the product according to following scenario(s): the Carbstones are glued together with the Masterbloc ECO lijmmortel 950 (packed) of Saint-Gobain Weber Benelux (see reference in Bibliography).",
      "referenceServiceLifeYears": 100,
      "geographicalRepresentativity": "The EPD is representative for the Belgian market. The Carbstones are produced at the manufacturing facility in Maasmechelen, Belgium.",
      "productionProcess": "Betonagglomeraten Gubbels N.V. mixes the raw materials and presses this mixture into a block shape on a vibrating press. Next, this pressed mix goes to a climate chamber, here the liquid CO2 is injected into the process. It is measured how much CO2 enters the chamber and how much is absorbed by the stones through carbonation and calcium carbonate is created. After this, the stones are polished if necessary. Finally, they go to a stacking/packing machine, which sorts the Carbstones for storage and transport to customers.",
      "referenceFlow": {
        "@type": "schema:QuantitativeValue",
        "schema:value": 1,
        "schema:unitCode": "m2",
        "description": "The results are declared for 1 m2 Carbstone Kimblok with dimensions 29/09/22. Packaging is included."
      },

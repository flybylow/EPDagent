          "unit": "W/m2K",
          "comment": null
        },
        {
          "property": "Acoustic insulation",
          "standard": "EN ISO 140-3\nEN ISO 717-1",
          "value": "till 47.1",
          "unit": "dB (-1,-4)",
          "comment": null
        },
        {
          "property": "Air tightness",
          "standard": "EN 1026\nEN12207",
          "value": "C5",
          "unit": null,

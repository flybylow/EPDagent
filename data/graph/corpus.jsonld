    {
      "@id": "http://localhost:3000/id/org/316279078ee4",
      "@type": "schema:Organization",
      "schema:name": "Aliplast NV",
      "schema:address": null,
      "schema:addressCountry": "BE"
    },
    {
      "@id": "http://localhost:3000/id/person/500595ad76a6",
      "@type": "schema:Person",
      "schema:name": "Bob Roijen & Agnes Schuurmans (SGS INTRON B.V.)",
      "verificationType": "independent_third_party"
    },
    {
      "@id": "http://localhost:3000/id/epd/http%3A%2F%2Flocalhost%3A3000%2Fid%2Fepd%2FB-EPD%2520025.0297.004-01.00.00%2520Aliplast%2520STAR75%2520Dubbel%2520EN%2520-%2520signed/product",
      "@type": "ProductSection",
      "description": "Star 75 double casement & Star 75 double casement turn-and-tilled are aluminium window systems. The frames are made of aluminium profiles with thermal breaks. Elastomer seals are used to ensure watertightness.\n\nThis is a specific EPD for a specific product produced by Aliplast NV.",
      "intendedUse": "Window system is used in a window in all types of residential and non-residential buildings, both for new-build and renovations.",
      "installation": "The scope of this product is 'AS PRODUCED'.\nMaterials for fixation and installation (glass) are not included. \nThis EPD only includes the environmental impact related to the product itself and end-of-life treatment of packaging.\nFor installing the product, one should follow the instructions provided by Aliplast N.V. The following scenarios are possible:\n- Mounting brackets\n- - Fixation screws.\nThis may lead to the need of additional products and materials for which the impact is not included in this EPD and which shall be taken into account at building level. More detailed information on these scenarios can be found in the chapter \"Additional technical information for scenario development at building\".",
      "referenceServiceLifeYears": 60,
      "geographicalRepresentativity": "The EPD is representative of a product produced, installed and discarded in Belgium.\nThe EPD is representative for the Belgian market.",
      "productionProcess": "The assembly process is generally carried out on site. \nThe following operations are carried out to produce the main parts: \n1. Preparation of the aluminium profile (powder coating), mainly by sawing and milling. \n2. Production of the frame by assembling the various profiles using connectors and fixing with bolts or glue. The connectors used are mainly made of aluminium. \n3. Positioning and fixing the various joints. \n4. Application of the infill (e.g. glazing, opaque panels). \n5. Integration of equipment (where applicable).",
      "referenceFlow": {
        "@type": "schema:QuantitativeValue",
        "schema:value": 1,
        "schema:unitCode": "m2",
        "description": "COVERAGE OF 1 M2 OF EXTERNAL WALL WITH A WINDOW (WITH A SURFACE OF < 2.3 M2) PROVIDING THERMAL AND ACOUSTIC INSULATION, NATURAL LIGHT TRANSMISSION, WATER AND AIR TIGHTNESS AND NATURAL VENTILATION OVER A LIFESPAN OF 60-YEARS."
      },
      "technicalProperties": [
        {
          "property": "Dimensions",
          "standard": "metric",
          "value": "1.23 x 1.48",
          "unit": "m",
          "comment": null
        },
        {

      "@id": "http://localhost:3000/id/epd/http%3A%2F%2Flocalhost%3A3000%2Fid%2Fepd%2FB-EPD%2520023.0221.003-01.00.00%2520CEM%2520IIIB%252042%252C5%2520N-LHSR%2520bulk%2520%25E2%2580%259CECOPlanet%25E2%2580%259D%2520EN_%2520signed/lca-table/lca_resource",
      "@type": "LcaTable",
      "tableKey": "lca_resource",
      "tableTitle": "RESOURCE USE",

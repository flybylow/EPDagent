    {
      "@id": "http://localhost:3000/id/operator/B-EPD",
      "@type": "ProgramOperator",
      "schema:name": "Federal Public Service of Health, Food Chain Safety and Environment",
      "operatorCode": "B-EPD"
    },
    {
      "@id": "http://localhost:3000/id/org/b2adb0d79871",
      "@type": "schema:Organization",
      "schema:name": "DERBIGUM",
      "schema:address": null,
      "schema:addressCountry": "BE"
    },
    {
      "@id": "http://localhost:3000/id/person/1e4d92208da9",
      "@type": "schema:Person",
      "schema:name": "Naeem Adibi (WeLOOP S.A.R.L)",
      "verificationType": "independent_third_party"
    },
    {
      "@id": "http://localhost:3000/id/epd/http%3A%2F%2Flocalhost%3A3000%2Fid%2Fepd%2FBEPD_024.0156.002-01.00.00_Derbigum%2520NT%25204-%2520EN%2520-%2520signed/product",
      "@type": "ProductSection",
      "description": "Derbigum NT is a bituminous waterproofing membrane modified by plastomeric polymers. Derbigum NT partly consists of bitumen extracted from recycled cutting waste and used bituminous roofing membranes (Derbitumen).\nThe upper side of the Derbigum NT membrane is fitted with two reinforcements , one glass-fibre and one non-woven polyester (both with a recycled content). This gives the membrane dimensional stability, and tear and puncture resistance.\nThe reference product has a thickness of 4 mm (Derbigum NT4 – noted DG4). The alternative thickness is 3 mm (Derbigum NT3 – noted DG3).\nDerbigum NT 4 is a product.\nThis is a specific EPD from a single company.",
      "intendedUse": "reinforced bituminous sheet for roof waterproofing\nThe product can be used on different types of substrates: wood, concrete, and sheet steel",
      "installation": "Materials for fixation and installation are included. It consists in propane for fully torch installation.\nThis EPD includes the necessary overlap of two strips of membrane to ensure the tightness (10,5%), and the installation losses (2%), \nDetailed information on this scenario can be found in the chapter \"Data of the underlying scenario's\".\nYou can find more detailed information helping to develop alternative scenarios in the chapter \"Technical information for scenario development at building level\" (cold bonded with bituminous cold glue, mechanical fixing with screw, loose lay under ballast).",
      "referenceServiceLifeYears": 40,
      "geographicalRepresentativity": "The B-EPD is representative for the Belgian market for A123, A4, A5, B, C and D.\nThe assumed market for the installation, the use phase and the end-of-life is Belgium.",
      "productionProcess": "Virgin bitumen, recycled mix and plastomer/elastomer are mixed and stored in liquid phase at 180°C in 16-tonne tanks. The mixture is impregnated with a double reinforcement of glass cloth and nonwoven polyester (for Derbigum NT membranes), then laminated by calendering. Once cooled, the bottom and top side of the membrane are then treated with chalk or talc, then cut into 7,27 m lengths and rolled up. Finally, it is packaged. Any waste as a result of the production is collected and internally recycled.\nWater is used to cool the bitumen during the process in a closed-circuit.",
      "referenceFlow": {
        "@type": "schema:QuantitativeValue",
        "schema:value": 1.105,
        "schema:unitCode": "m2",
        "description": "FUNCTIONAL UNIT (FU):: \"ENSURE THE WATERPROOFING OF 1 M² OF ROOF WITH BITUMINOUS MEMBRANE, FROM CRADLE-TO-GRAVE, WITH ACTIVITIES NEEDED FOR A STUDY PERIOD OF 60 YEARS FOR THE BUILDING\". THE FU INCLUDES THE OVERLAP NECESSARY TO ENSURE A CORRECT INSTALLATION. THE OVERLAP IS 10.5%, AND THE FU CORRESPOND TO 1.105 M² OF MEMBRANE."
      },

    {
      "@id": "http://localhost:3000/id/operator/B-EPD",
      "@type": "ProgramOperator",
      "schema:name": "Federal Public Service Health, Food Chain Safety and Environment",
      "operatorCode": "B-EPD"
    },
    {
      "@id": "http://localhost:3000/id/org/bebe357d7ebb",
      "@type": "schema:Organization",
      "schema:name": "Kingspan Insulation BV",
      "schema:address": null,
      "schema:addressCountry": null
    },
    {
      "@id": "http://localhost:3000/id/person/f65746f88cd1",
      "@type": "schema:Person",
      "schema:name": "Vinçotte nv",
      "verificationType": "independent_third_party"
    },
    {
      "@id": "http://localhost:3000/id/epd/http%3A%2F%2Flocalhost%3A3000%2Fid%2Fepd%2FB-EPD%252023.0191.003_01.00.01%2520EN%2520Kingspan%2520Kooltherm%2520K8%2520-%2520signed/product",
      "@type": "ProductSection",
      "description": "The Kingspan Kooltherm® K8 is a premium performance insulation board with a fibre-free rigid thermoset phenolic core, faced on both sides with a perforated aluminium multilayer facing that is autohesively bonded to the insulation core during manufacture.\n\nPhenolic foam is produced by the use of phenolic resin, a catalyst, additives and blowing agent. The cell structure is formed in the resin under the influence of heat released during the chemical reaction. Hereby, the blowing agent is incorporated into the material which forms a solid and very fine cell structure, which is nearly 100% closed.\n\nThis is a specific EPD from a single company, Kingspan insulation BV.",
      "intendedUse": "Kooltherm® K8 is suitable for use as cavity wall insulation.",
      "installation": "Materials for fixation and installation are not included. Regarding installation this EPD only includes the environmental impact related to the product itself: It also includes the loss of material during construction. The additional needed production, transport and end-of-life of the lost material during construction is included. The end-of-life of packaging material up to the end-of-waste state is also included. \n\nFor installing the product following scenario is possible: Mechanical fixing. This may lead to the need of additional products and materials for which the impact is not included in this EPD and which shall be taken into account at building level. For questions about installation please contact our Technical Service Department: Techline.be@kingspan.com\n\nIn chapter 15 an overview is given on the qualitative assessment of the reversibility of Kooltherm® K8.",
      "referenceServiceLifeYears": 75,
      "geographicalRepresentativity": "The EPD is representative for the Belgian market.\nKooltherm® K8 is produced by Kingspan Insulation B.V. at the manufacturing facility in Tiel, the Netherlands.",
      "productionProcess": "Kingspan Kooltherm® is made through a manufacturing process in which a foam forms an insulating core between two facing elements. At the start of the process a mix of chemicals is added directly to the bottom layer of facing and then expands to meet the top layer of facing. As it dries, the foam becomes tacky and adheres itself to the facing, top and bottom. Once it has reached the necessary thickness the foam is cooked under pressure. It is then moved onto a secondary oven to cure and harden, becoming bright pink in colour. The insulation boards are then cut into the necessary sizes, packaged and sent to the loading bay for collection.",
      "referenceFlow": {
        "@type": "schema:QuantitativeValue",
        "schema:value": 1,
        "schema:unitCode": "m2",
        "description": "1 m2 thermal insulation with a thickness of 80 mm which gives a RD-value of 3,80 m2·K/W."
      },
      "technicalProperties": [
        {
          "property": "Thickness",
          "standard": null,
          "value": "80",
          "unit": "mm",
          "comment": null
        },
        {
          "property": "Density",
          "standard": null,
          "value": "35",
          "unit": "kg/m3",
          "comment": null
        },
        {
          "property": "Thermal conductivity λd acc. to EN 13166",
          "standard": "EN 13166",
          "value": "0,021",
          "unit": "W/(m·K)",
          "comment": null
        },
        {
          "property": "RD-value",
          "standard": null,
          "value": "3,80",
          "unit": "m2·K/W",
          "comment": null
        }
      ]
    },
    {
      "@id": "http://localhost:3000/id/epd/http%3A%2F%2Flocalhost%3A3000%2Fid%2Fepd%2FB-EPD%252023.0191.003_01.00.01%2520EN%2520Kingspan%2520Kooltherm%2520K8%2520-%2520signed/lca-study",
      "@type": "LcaStudy",
      "sectionTitle": "3 LCA-STUDY",
      "standardsAndMethodology": "Carbon offsetting is not allowed in the EN 15804 and hence not taken into account in the calculations.",
      "lcaSoftwareAndDatabase": "For the calculation of the LCA results, the software program SimaPro 9.1.1 has been used. The Ecoinvent v3.6 database (2019) is used for background data",
      "functionalUnit": "The declared unit in this EPD is 1 m2 thermal insulation with a thickness of 80 mm which gives a RD-value of 3,80 m2·K/W.",
      "systemBoundaries": "System boundaries (parsed from PDF diagram — no AI)\nPage 11\nDeclared modules (☒): A1, A2, A3, A4, A5, C1, C2, C3, C4, D\nNot declared (☐): B1, B2, B3, B4, B5, B6, B7\nBy life-cycle stage:\nProduct stage: A1, A2, A3\nConstruction installation stage: A4, A5\nEnd of life stage: C1, C2, C3, C4\nBeyond the system boundaries: D\n\nModule labels (vertical text):\nA1: materials\nA2: Transport\nA3: Manufacturing\nA4: Transport\nA5: Construction\nB1: Use\nB2: Maintenance\nB3: Repa\nB4: Replacement\nB5: Refurbishment\nB6: Operational energy use\nB7: Operational water use\nC1: construction\nC2: Transport\nC3: Waste processing\nC4: Disposal\nD: Recovery",
      "productionSites": "The data used for the LCA are specific for this product which is manufactured by a single manufacturer in a single production site.",
      "cutOffCriteria": "The total of neglected input flows per module is less than 5% of energy usage and mass as prescribed by EN15804+A2.",
      "allocation": "Different types of Kooltherm® insulation boards are produced at the production plant in Tiel (NL). For the use of energy there is only data available for the total site. This data has been allocated to Kooltherm® K8 based on physical properties. Production waste was allocated similarly.",
      "dataQuality": "Company specific data for the product stage have been collected by Kingspan Insulation and were provided to Nibe (R<Think application).",
      "timeRepresentativeness": "Manufacturer specific data for the location Tiel have been collected for the year 2019.",
      "impactAssessment": "The characterization factors from EC-JRC were applied. No additional or deviating characterization factors were used.",
      "additionalParagraphs": [
        "Following processes were excluded for the inventory:\n- Impact of infrastructures\n- Consumables necessary for the functioning of the process, production, maintenance and end-of-life of equipment\n- Environmental impacts caused by the personnel of the production plants are not included in the LCA, e.g. waste from the cafeteria and sanitary installations or environmental effects caused by commuter traffic. Heating or cooling of the plants in order to ensure a comfortable indoor climate for the personnel could not be distinguished during the data collection and is therefore included.",
        "The total mass of biogenic carbon containing materials is less than 5 % of the total mass of the product and accompanying packaging.",
        "Kingspan Kooltherm® K8 can be produced in all thicknesses between 20 and 200mm (single layer product) and covers a RD range of 0.95 – 9.50. The results in this EPD can be used to recalculate to other thicknesses / RD-values. Where the foam-core is the scalable part and the facer the non-scalable part.",
        "All electricity used during production comes from renewable sources. By generating energy on-site with PV panels and with procured energy from fully certified renewable sources (Guarantees of Origin)."
      ],
      "subsections": [
        {
          "number": "3.1",
          "title": "Date of LCA-study",
          "content": "July 2022"
        },
        {
          "number": "3.2",
          "title": "Software",
          "content": "For the calculation of the LCA results, the software program SimaPro 9.1.1 has been used."
        },
        {
          "number": "3.3",
          "title": "Information on allocation",
          "content": "Different types of Kooltherm® insulation boards are produced at the production plant in Tiel (NL). For the use of energy there is only data available for the total site. This data has been allocated to Kooltherm® K8 based on physical properties. Production waste was allocated similarly."
        },
        {
          "number": "3.4",
          "title": "Informatie on cut off",
          "content": "The total of neglected input flows per module is less than 5% of energy usage and mass as prescribed by EN15804+A2."
        },
        {
          "number": "3.5",
          "title": "Information on excluded processes",
          "content": "Following processes were excluded for the inventory:\n- Impact of infrastructures\n- Consumables necessary for the functioning of the process, production, maintenance and end-of-life of equipment\n- Environmental impacts caused by the personnel of the production plants are not included in the LCA, e.g. waste from the cafeteria and sanitary installations or environmental effects caused by commuter traffic. Heating or cooling of the plants in order to ensure a comfortable indoor climate for the personnel could not be distinguished during the data collection and is therefore included."
        },
        {
          "number": "3.6",
          "title": "Information on biogenic carbon modelling",
          "content": "The total mass of biogenic carbon containing materials is less than 5 % of the total mass of the product and accompanying packaging."
        },
        {
          "number": "3.7",
          "title": "Information on carbon offsetting",
          "content": "Carbon offsetting is not allowed in the EN 15804 and hence not taken into account in the calculations."
        },
        {
          "number": "3.8",
          "title": "Additional or deviating characterization factors",
          "content": "The characterization factors from EC-JRC were applied. No additional or deviating characterization factors were used."
        },
        {
          "number": "3.9",
          "title": "Description of the variability",
          "content": "The declared unit in this EPD is 1 m2 thermal insulation with a thickness of 80 mm which gives a RD-value of 3,80 m2·K/W. Kingspan Kooltherm® K8 can be produced in all thicknesses between 20 and 200mm (single layer product) and covers a RD range of 0.95 – 9.50. The results in this EPD can be used to recalculate to other thicknesses / RD-values. Where the foam-core is the scalable part and the facer the non-scalable part."
        },
        {
          "number": "3.10",
          "title": "Specificity",
          "content": "The data used for the LCA are specific for this product which is manufactured by a single manufacturer in a single production site."
        },
        {
          "number": "3.11",
          "title": "Period of data collection",
          "content": "Manufacturer specific data for the location Tiel have been collected for the year 2019."
        },
        {
          "number": "3.12",
          "title": "Information on data collection",
          "content": "Company specific data for the product stage have been collected by Kingspan Insulation and were provided to Nibe (R<Think application)."
        },
        {
          "number": "3.13",
          "title": "Database used for background data",
          "content": "The Ecoinvent v3.6 database (2019) is used for background data"
        },
        {
          "number": "3.14",
          "title": "Energy mix",
          "content": "All electricity used during production comes from renewable sources. By generating energy on-site with PV panels and with procured energy from fully certified renewable sources (Guarantees of Origin)."
        }
      ]
    },

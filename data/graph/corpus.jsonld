    {
      "@id": "http://localhost:3000/id/epd/http%3A%2F%2Flocalhost%3A3000%2Fid%2Fepd%2FB-EPD%2520025.0262.004-01.00.00%2520Beton%2520Agglo%2520Carbstones%2520Kimblok%2520EN%2520-%2520signed/composition",
      "@type": "Composition",

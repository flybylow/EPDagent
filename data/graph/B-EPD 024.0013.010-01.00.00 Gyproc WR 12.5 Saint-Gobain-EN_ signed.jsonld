      "@id": "http://localhost:3000/id/epd/http%3A%2F%2Flocalhost%3A3000%2Fid%2Fepd%2FB-EPD%2520024.0013.010-01.00.00%2520Gyproc%2520WR%252012.5%2520Saint-Gobain-EN_%2520signed/lca-table/lca_resource",
      "@type": "LcaTable",
      "tableKey": "lca_resource",
      "tableTitle": "RESOURCE USE",

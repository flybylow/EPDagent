    {
      "@id": "http://localhost:3000/id/epd/http%3A%2F%2Flocalhost%3A3000%2Fid%2Fepd%2FB-EPD-LAMBDA%252035%2520NAKED-Ursa-026.0184.001-EN-signed/composition",

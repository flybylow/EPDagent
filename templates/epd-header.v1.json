        { "id": "product_description", "label": "Product type", "path": "phase2.product_description", "format": "text" },
        { "id": "epd_number", "label": "EPD number", "path": "phase2.epd_number", "format": "text" },
        { "id": "issued", "label": "Date of issue", "path": "phase2.validity.issued", "format": "date-eu" },
        { "id": "valid_until", "label": "Valid until", "path": "phase2.validity.valid_until", "format": "date-eu" },
        { "id": "verification_statement", "label": "Verification", "path": "phase2.verification_statement", "format": "text" },
        { "id": "conformity_basis", "label": "Conformity basis", "path": "phase2.conformity_basis", "format": "text" },
        { "id": "standards_conformity", "label": "Standards conformity", "path": "phase2.standards_conformity", "format": "text" },
        { "id": "program_operator", "label": "Program operator", "path": "phase2.program_operator", "format": "text" },
        { "id": "language", "label": "Document language", "path": "phase1.language", "format": "text" },
        { "id": "filename_pattern", "label": "Filename pattern", "path": "phase1.pattern", "format": "text" }
      ]
    },
    {
      "id": "declaration_scope",
      "title": "Declaration scope",
      "fields": [
        { "id": "declared_scope", "label": "Declared unit & scope", "path": "phase2.declared_scope", "format": "text" },
        { "id": "declared_modules", "label": "Modules declared", "path": "phase2.declared_modules", "format": "list" },
        { "id": "declared_value", "label": "Declared value", "path": "phase2.declared_unit.value", "format": "text" },
        { "id": "declared_unit", "label": "Declared unit", "path": "phase2.declared_unit.unit", "format": "text" }
      ]
    },
    {
      "id": "producer",
      "title": "Producer",
      "fields": [
        { "id": "producer_name", "label": "Name", "path": "phase2.producer.name", "format": "text" },
        { "id": "producer_address", "label": "Address", "path": "phase2.producer.address", "format": "text" },
        { "id": "producer_country", "label": "Country (ISO)", "path": "phase2.producer.country", "format": "text" }
      ]
    },
    {
      "id": "references",
      "title": "References & verification",
      "fields": [
        { "id": "pcr_reference", "label": "PCR reference", "path": "phase2.pcr_reference", "format": "text" },
        { "id": "verifier_name", "label": "Verifier", "path": "phase2.verifier.name", "format": "text" },
        {
          "id": "verifier_type",
          "label": "Verification type",
          "path": "phase2.verifier.type",
          "format": "enum",
          "enumLabels": {
            "independent_third_party": "Third party verified",
            "internal": "Internal verification",
            "unknown": "Unknown"
          }
        }
      ]
    }
  ]
